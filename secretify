#! /opt/homebrew/bin/bash

set -euo pipefail

ITER=200000
expand_path() { eval echo "$1"; }

read -r -p "Mode? (e)ncrypt or (d)ecrypt: " mode
mode="${mode,,}"

if [[ "$mode" == "e" || "$mode" == "encrypt" ]]; then
  read -r -p "Path to file to encrypt: " in_path
  in_path="$(expand_path "$in_path")"

  read -r -p "Output .enc path [$(basename "$in_path").enc]: " out_path
  out_path="${out_path:-$(basename "$in_path").enc}"
  out_path="$(expand_path "$out_path")"

  in_dir="$(cd "$(dirname "$in_path")" && pwd)"
  in_base="$(basename "$in_path")"

  tar -C "$in_dir" -cvf - "$in_base" \
    | openssl aes-256-cbc -pbkdf2 -iter "$ITER" -e -out "$out_path"
  exit
fi

if [[ "$mode" == "d" || "$mode" == "decrypt" ]]; then
  read -r -p "Path to .enc file to decrypt: " enc_path
  enc_path="$(expand_path "$enc_path")"

  read -r -p "Decrypt to (p)rint, (e)xtract, or (a)ppend? [p/e/a]: " out_mode
  out_mode="${out_mode,,}"
  out_mode="${out_mode:-p}"

  if [[ "$out_mode" == "p" || "$out_mode" == "print" ]]; then
    openssl aes-256-cbc -pbkdf2 -iter "$ITER" -d -in "$enc_path" | tar -xvO

  elif [[ "$out_mode" == "e" || "$out_mode" == "extract" ]]; then
    read -r -p "Directory to extract into [.]: " out_dir
    out_dir="${out_dir:-.}"
    out_dir="$(expand_path "$out_dir")"
    openssl aes-256-cbc -pbkdf2 -iter "$ITER" -d -in "$enc_path" | tar -xv -C "$out_dir"

  elif [[ "$out_mode" == "a" || "$out_mode" == "append" ]]; then
    read -r -p "File to append decrypted contents to: " append_path
    append_path="$(expand_path "$append_path")"
    openssl aes-256-cbc -pbkdf2 -iter "$ITER" -d -in "$enc_path" | tar -xvO >> "$append_path"
  fi
fi
